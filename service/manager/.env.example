# Docker Compose Config
COMPOSE_PROJECT_PREFIX = dev
COMPOSE_NETWORK = dev
COMPOSE_RESTART_POLICY = unless-stopped

# Image Names
NGINX_PROXY_IMAGE = jc21/nginx-proxy-manager:latest
PORTAINER_IMAGE = portainer/portainer-ce:latest
PORTAINER_AGENT_IMAGE = portainer/agent:2.19.5
UPTIME_KUMA_IMAGE = louislam/uptime-kuma:latest
SYNCTHING_IMAGE = syncthing/syncthing
WATCHTOWER_IMAGE = containrrr/watchtower
TRAEFIK_IMAGE = traefik:latest
WHOAMI_IMAGE = traefik/whoami:latest

# Port 310XX
TRAEFIK_DASHBOARD_PORT = 31000
NGINX_PROXY_DASHBOARD_PORT = 31001
PORTAINER_HTTPS_PORT = 31002
PORTAINER_HTTP_PORT = 31003
PORTAINER_AGENT_PORT = 31004
UPTIME_KUMA_PORT = 31005
SYNCTHING_PORT = 31006
WATCHTOWER_PORT = 31007

# Traefik Config
TRAEFIK_LOG_LEVEL = INFO
ACME_EMAIL = kaushikrb909@gmail.com
TRAEFIK_DASHBOARD_HOST = traefik.localhost
# Generate with: docker run --rm httpd:2.4-alpine htpasswd -nbB admin 'yourpassword' | sed -e 's/\$/\$\$/g'
TRAEFIK_DASHBOARD_AUTH = admin:$$2y$$05$$...hashed-password...
WHOAMI_HOST = whoami.localhost
